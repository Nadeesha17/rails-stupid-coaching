<div class="card shadow-lg p-4">
  <h1 class="text-primary text-center">Ask Your Coach Anything</h1>

  <%= form_with url: "/answer", method: :get, class: "mt-4" do %>
    <div class="mb-3">
      <label for="question" class="form-label">Your question:</label>
      <%= text_field_tag :question, params[:question], class: "form-control" %>
    </div>
    <div class="text-center">
      <%= submit_tag "Ask!", class: "btn btn-primary px-4" %>
    </div>
  <% end %>
</div>
